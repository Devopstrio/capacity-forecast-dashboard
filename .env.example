# Capacity Forecast Dashboard - Environment Template

# --- Feature Toggles ---
ENABLE_OIDC=false
ENABLE_REDIS_CACHE=false
ENABLE_BACKGROUND_JOBS=true
ENABLE_MULTI_TENANCY=false

# --- Backend Config ---
PROJECT_NAME="Capacity Forecast Dashboard API"
API_V1_STR="/api/v1"
SECRET_KEY="replace-this-with-a-very-secure-random-string-in-production"
ACCESS_TOKEN_EXPIRE_MINUTES=11520

# --- Database ---
POSTGRES_SERVER=db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=capacity_db
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_SERVER}/${POSTGRES_DB}

# --- Observability ---
OTEL_SERVICE_NAME=capacity-backend
LOG_LEVEL=INFO

# --- Frontend Config (Vite injects VITE_ prefixed vars) ---
VITE_API_URL=http://localhost:8000/api/v1
VITE_APP_TITLE="Capacity Forecast Operations Center"
